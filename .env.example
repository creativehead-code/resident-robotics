# ── Google Sheet submissions (Apps Script web app) ───────────────────
# See docs/google-sheet-setup.md for the 3-minute setup.
# The deployed Apps Script web-app URL (…/exec):
SHEET_WEBHOOK_URL=
# A long random string — must match SECRET in the Apps Script:
SHEET_SHARED_SECRET=

# ── Google Analytics 4 ───────────────────────────────────────────────
# Your GA4 Measurement ID (looks like G-XXXXXXXXXX). When set, GA loads
# automatically. Leave empty to disable analytics.
NEXT_PUBLIC_GA_ID=
